# Prisma / Supabase Postgres
#
# 앱 런타임(Next.js)은 src/lib/prisma.ts 가 DATABASE_URL 만 사용합니다.
# 로컬에서 P1001 "Can't reach database server at db.*.supabase.co" 가 나오면,
# db.* 호스트가 IPv6만 제공되거나 망에서 막힌 경우가 많습니다.
# → Dashboard → Project Settings → Database → Connection string →
#   "Transaction pooler" (또는 URI 모드에서 Pooler) 로 표시된 URI를 DATABASE_URL 로 쓰세요.
#   호스트는 보통 aws-0-<지역>.pooler.supabase.com, 포트 6543, 사용자명 postgres.<프로젝트ref> 입니다.
#
# 예시 형식 (비밀번호·지역·ref 는 대시보드 값으로 교체):
# DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&uselibpqcompat=true"
#
# Prisma CLI(db push 등)는 prisma.config.ts 가 DIRECT_URL 을 씁니다.
# 직접 연결이 안 되면 Session pooler URI 를 DIRECT_URL 에 넣는 방법도 있습니다.
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true"
# uselibpqcompat=true → node-pg 가 sslmode=require 관련 deprecation 경고를 내지 않도록(libpq 의미와 맞춤)

DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&uselibpqcompat=true"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true"

# Supabase Auth (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
#
# R2 미사용 시 게시글·프로필 이미지 업로드용 Supabase Storage (서버 전용 — 절대 클라이언트에 노출 금지)
# Dashboard → Storage → New bucket → 이름 예: uploads → Public bucket 으로 생성
# 서버 전용(클라이언트에 넣지 말 것). Vercel 은 Production/Preview 모두에 넣었는지 확인.
# 토큰 비밀번호 재설정·회원가입(admin createUser)에 필수 — 없으면 503 후 클라이언트 signUp 폴백(이메일 한도 영향)
# SUPABASE_SERVICE_ROLE_KEY="eyJ... (Settings → API → service_role)"
# SUPABASE_STORAGE_BUCKET="uploads"
#
# 공개 사이트 URL (이메일 인증·비밀번호 재설정 링크가 여기로 감). 끝의 / 없이.
# Vercel 환경 변수에도 동일하게 넣는 것을 권장 (빌드에 포함됨).
# NEXT_PUBLIC_SITE_URL="https://aisleshub.com"
#
# SEO — Search Console HTML 태그(meta google-site-verification). 둘 중 하나만 넣어도 됩니다.
# 서버 전용(클라 번들에 포함 안 함): GOOGLE_SITE_VERIFICATION
# 또는 빌드에 포함돼도 되면: NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION
# Search Console → 설정 → 소유권 확인 → "HTML 태그" 에 표시된 content 값만 붙여넣기.
# GOOGLE_SITE_VERIFICATION="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#
# (선택) 비밀번호 찾기 redirectTo 를 수동으로 고정할 때만. 보통 비울 것.
# NEXT_PUBLIC_PASSWORD_RECOVERY_REDIRECT_TO="https://aisleshub.com/auth/reset-callback"
#
# Supabase → Authentication → Email Templates → Reset password:
#   링크는 href="{{ .ConfirmationURL }}" 한 덩어리로 두세요.
#   verify URL 을 직접 만들면서 redirect_to={{ .SiteURL }} 만 넣으면
#   메일에 redirect_to=https://도메인 만 들어가 메인으로만 갑니다.
#   → {{ .RedirectTo }} 또는 전체 {{ .ConfirmationURL }} 을 사용하세요.
#
# Supabase Dashboard → Authentication → URL Configuration
#   • Site URL → 실제 서비스 도메인 (예: https://aisleshub.com). localhost 로 두면 메일 링크가 localhost 로 갈 수 있음.
#   • Redirect URLs 에 아래를 추가 (로컬 개발 시 localhost 도 추가).
#     비밀번호 찾기 → /auth/reset-callback → /auth/reset-password (쿼리 없이 등록 가능).
#     메일에 redirect_to 가 루트만 찍히면 `https://YOUR_DOMAIN/**` 와일드카드도 추가해 볼 것.
#       https://YOUR_DOMAIN/auth/callback
#       https://YOUR_DOMAIN/auth/reset-callback
#       https://YOUR_DOMAIN/auth/reset-password
#       https://YOUR_DOMAIN/reset-password
#       https://YOUR_DOMAIN/**
#       http://localhost:3000/auth/callback
#       http://localhost:3000/auth/reset-callback
#       http://localhost:3000/auth/reset-password
#       http://localhost:3000/**
#
# 로컬에서만 인증 메일 링크를 localhost 로 받으려면:
#   NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Cloudflare R2 (프로필·게시글 미디어, S3 호환 API — 서버에서만 사용)
# 엔드포인트: 아래 둘 중 하나
#   (A) R2_ENDPOINT 전체 URL — 대시보드 R2 → 버킷 → S3 API 에 표시되는 값
#   (B) R2_ACCOUNT_ID 만 넣으면 https://{id}.r2.cloudflarestorage.com 자동 구성
# 퍼블릭 URL 베이스: 커스텀 도메인 또는 r2.dev (끝의 / 제거 권장, https:// 포함)
#   R2_PUBLIC_BASE_URL 또는 NEXT_PUBLIC_R2_PUBLIC_URL 또는 R2_PUBLIC_DOMAIN(Vercel 등에서 DOMAIN 이라고 넣은 경우)
# 엔드포인트는 R2_ENDPOINT 또는 R2_ACCOUNT_ID 중 하나면 됨 (ACCOUNT_ID 만 있으면 자동으로 *.r2.cloudflarestorage.com 구성)
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
# R2_ACCOUNT_ID="YOUR_ACCOUNT_ID"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL="https://pub-xxxxx.r2.dev"
# NEXT_PUBLIC_R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
# R2_PUBLIC_DOMAIN="https://pub-xxxxx.r2.dev"

# Google AI Studio — 레시피 상세「프롬프트 AI 해석」(서버 전용, 클라이언트에 넣지 말 것)
# Vercel: Project → Settings → Environment Variables → Production 및 Preview 모두에 등록 후 재배포
# 우선순위: GOOGLE_GENERATIVE_AI_API_KEY → GEMINI_API_KEY → GOOGLE_GENAI_API_KEY → GOOGLE_AI_API_KEY
# GOOGLE_GENERATIVE_AI_API_KEY="AIza..."
# GEMINI_API_KEY="AIza..."
# GOOGLE_GENAI_API_KEY="AIza..."
