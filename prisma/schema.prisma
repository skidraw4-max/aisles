// 1. Prisma 클라이언트 및 DB 연결 설정
// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url 부분은 아예 지워버리세요.
}

// 2. 사용자 모델 (Supabase Auth user.id 와 동일한 UUID 문자열)
model User {
  id         String   @id // auth.users.id (Supabase)
  username   String   @unique
  email      String   @unique
  avatarUrl  String? // Cloudflare R2 등 퍼블릭 URL
  /// USER · BUILDER · ADMIN — 공지 관리 등은 ADMIN 만 (세션·서버 액션에서 검증)
  role       Role     @default(USER)
  posts      Post[]
  postLikes  PostLike[]
  comments   Comment[]
  passwordResetTokens PasswordResetToken[]
  createdAt  DateTime @default(now())
}

/// 비밀번호 찾기 메일의 `?token=` 검증용 (Supabase 메일의 redirect_to 에 포함)
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// 3. 게시물 모델 (4개의 복도 통합 관리)
model Post {
  id          String      @id @default(uuid())
  category    Category
  title       String
  content     String?
  thumbnail   String?
  /// 대표 썸네일 외 추가 미디어 URL (최대 4개 + thumbnail = 5개까지)
  attachmentUrls String[] @default([])
  /// 상세·피드 조회수
  views       Int         @default(0)
  /// 좋아요 수(비정규화). 실제 누른 유저는 `likes` 관계(PostLike)
  likeCount   Int         @default(0)
  /// 메인 상단 등 에디터 픽 노출용
  isFeatured  Boolean     @default(false)
  /// 출시·외부 서비스 페이지 등 연결 URL (선택)
  externalLink String?
  /// GeekNews 크론 등 — 원문 URL로 중복 방지 (고유, 선택)
  geeknewsOriginalUrl String? @unique @db.VarChar(2048)
  /// Hacker News 크론 등 — 원문 URL로 중복 방지 (고유, 선택)
  hackerNewsOriginalUrl String? @unique @db.VarChar(2048)
  /// The Verge RSS 등 — 원문 URL로 중복 방지 (고유, 선택)
  vergeOriginalUrl String? @unique @db.VarChar(2048)
  /// AI Breakfast (Beehiiv) 등 — 원문 URL로 중복 방지 (고유, 선택)
  aiBreakfastOriginalUrl String? @unique @db.VarChar(2048)
  /// 해시태그 (#은 표시 시만 붙임)
  tags        String[]    @default([])
  /// 갤러리 이미지 역분석 — AI가 추정한 프롬프트 (캐시)
  aiReversePrompt String? @db.Text
  /// 갤러리 이미지 역분석 전체 JSON (Gemini 응답)
  aiImageAnalysis Json?
  author      User        @relation(fields: [authorId], references: [id])
  authorId    String
  metadata    AiMetadata?
  launchInfo  LaunchInfo?
  /// 좋아요를 누른 유저와의 관계 (PostLike)
  likes       PostLike[]
  comments    Comment[]
  createdAt   DateTime    @default(now())
}

// 게시글 좋아요 (누가 눌렀는지 추적, Post.likeCount와 동기화)
model PostLike {
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([postId, userId])
  @@index([userId])
}

/// 게시글 상세 댓글 (작성자는 `User`, 로그인 유저만 POST API로 작성)
model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([authorId])
}

// 4. AI 레시피 및 빌드 정보 (Lab/Build 복도용 상세 데이터)
model AiMetadata {
  postId      String  @id
  post        Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  modelName   String? // 예: GPT-4o, Midjourney
  prompt      String? @db.Text
  params      Json?   // Seed, Temp 등 설정을 JSON 형태로 저장
  /// `analyzePostPromptAnalysis` 결과 캐시 (프롬프트 지문과 함께만 유효)
  promptAnalysis           Json?
  promptAnalysisPromptHash String? @db.VarChar(64)
  /// 등록 직후 백그라운드 Gemini 분석 작업 상태 (null = 레거시·수동 분석만 해당)
  promptAnalysisStatus     PromptAnalysisJobStatus?
}

// 5. 서비스 홍보 정보 (Launchpad 복도용 상세 데이터)
model LaunchInfo {
  postId      String  @id
  post        Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  serviceUrl  String? // 서비스 바로가기 링크
  status      String? // BETA, LIVE 등 상태
}

/// LAB 프롬프트 자동 분석(등록 후 비동기) 작업 상태
enum PromptAnalysisJobStatus {
  PENDING
  READY
  FAILED
}

// 6. 열거형 데이터 (고정된 선택지)
enum Role {
  USER
  BUILDER
  ADMIN
}

enum Category {
  RECIPE  // 프롬프트 복도 (LAB)
  GALLERY // 아트 복도
  LOUNGE  // 라운지 · 텍스트 중심 (썸네일 선택)
  GOSSIP  // 소셜·가십 복도
  BUILD   // 빌드 복도
  LAUNCH  // 서비스 복도
  TREND   // 레거시(구 테크 트렌드) — 신규 외부 뉴스는 LOUNGE
}

/// 관리자(BO)에서 수정 가능한 UI 카피 (메뉴·헤드라인·탭 등)
model UiConfig {
  key         String   @id
  value       String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// 사이트 상단 롤링 공지 등
model Notice {
  id        String   @id @default(cuid())
  title     String
  /// 공지 본문 (상세 페이지 `/notices/[id]` 에 표시)
  content   String   @default("") @db.Text
  /// 선택: 본문 외 추가 이동 링크(외부·내부). 롤링 바는 항상 상세 페이지로만 연결
  link      String?
  /// 상단 롤링 바 노출 여부
  isRolling Boolean  @default(false)
  /// 높을수록 먼저 노출
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRolling, priority(sort: Desc), createdAt(sort: Desc)])
}